# Bridge root — MUST match `messenger-bridge-directory' in messenger-bridge.el
# (the SAME directory the WhatsApp adapter uses — one shared bridge).
MESSENGER_BRIDGE_DIR=/Users/you/.emacs.d/messenger-bridge

# signal-cli binary (brew installs to /opt/homebrew/bin/signal-cli)
SIGNAL_CLI=signal-cli

# Your Signal number (+E.164) — the account signal-cli is linked to.
SIGNAL_ACCOUNT=+49XXXXXXXXXX

# Optional signal-cli config/data dir (--config). Empty = signal-cli default.
SIGNAL_CONFIG=

# SAFETY whitelist: comma-separated sender numbers (+E.164) whose inbound
# messages are relayed. Empty on first run; senders are logged so you can
# discover and whitelist them.
SIGNAL_ALLOWED=

# Outbox poll interval (ms)
SIGNAL_POLL_MS=500

# Device name shown in Signal ▸ Linked Devices
SIGNAL_DEVICE_NAME=emacs-bridge
